PORT=3000

# Neon/Supabase/Postgres connection string.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Telegram Bot API token from BotFather.
TELEGRAM_BOT_TOKEN="replace_me"

# Only this Telegram user can use the vault. Leave empty once to have the bot tell you your user id.
AUTHORIZED_TELEGRAM_USER_ID=""

# PIN requested before showing passwords.
MASTER_PIN="123456"

# Secret used to encrypt stored passwords. Use a long random value.
VAULT_MASTER_KEY="replace_with_a_long_random_secret_at_least_32_chars"
