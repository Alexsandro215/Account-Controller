PORT=3000

# Neon/Supabase/Postgres connection string.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# WhatsApp Cloud API.
WHATSAPP_TOKEN="replace_me"
WHATSAPP_PHONE_NUMBER_ID="replace_me"
WHATSAPP_VERIFY_TOKEN="choose_a_webhook_verify_token"

# Only this WhatsApp number can use the vault. Digits only, including country code.
AUTHORIZED_PHONE="5215555555555"

# PIN requested before showing passwords.
MASTER_PIN="123456"

# Secret used to encrypt stored passwords. Use a long random value.
VAULT_MASTER_KEY="replace_with_a_long_random_secret_at_least_32_chars"
